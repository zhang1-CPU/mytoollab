<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Color Picker – HEX to RGB to HSL Color Converter | My Tool Lab</title>
  <meta name="description" content="Free online color picker and converter. Select colors visually and convert between HEX, RGB, RGBA, HSL, HSLA color formats. Copy codes instantly." />
  <link rel="canonical" href="https://www.zlbox.site/tools/image/color-picker.html" />
  <meta name="google-site-verification" content="google4bd1e08685667667" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5420550088713746" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="../../css/components.css" />
  <style>
    .swatch{width:100%;height:140px;border-radius:10px;background:#2563eb;border:1px solid var(--border);transition:background-color .15s;}
    input[type=color]{width:100%;height:48px;border:1px solid var(--border);border-radius:8px;cursor:pointer;padding:4px;background:#fff;}
    .hex-row{display:flex;gap:8px;align-items:center;}
    .hex-row input{flex:1;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-family:ui-monospace,Consolas,monospace;font-size:1rem;text-transform:uppercase;background:#fff;color:var(--text);outline:none;}
    .hex-row input:focus{border-color:var(--brand);}
    .fmt-row{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 12px;background:var(--bg);border:1px solid var(--border);border-radius:8px;margin-bottom:8px;}
    .fmt-label{font-size:.85rem;font-weight:700;color:var(--muted);min-width:60px;}
    .fmt-value{font-family:ui-monospace,Consolas,monospace;font-size:.9rem;color:var(--text);flex:1;overflow-x:auto;white-space:nowrap;margin:0 10px;}
    .copied{background:#16a34a !important;}
  </style>

  <meta property="og:image" content="https://www.zlbox.site/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Color Picker" />
  <meta name="twitter:description" content="Pick and adjust colors" />
  <meta name="twitter:image" content="https://www.zlbox.site/og-image.png" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta name="robots" content="index, follow" />

  <script type="application/ld+json">{"@context": "https://schema.org", "@type": "WebApplication", "name": "Color Picker", "description": "Pick and adjust colors", "url": "https://www.zlbox.site/tools/image/color-picker.html", "applicationCategory": "UtilityApplication", "operatingSystem": "Any", "offers": {"@type": "Offer", "price": "0", "priceCurrency": "USD"}}</script>

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9V6L0Z956X"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-9V6L0Z956X');</script>
</head>
<body>
<div class="container-md">
  <div class="hero">
    <div class="breadcrumb"><a href="../../index.html">Home</a> &rsaquo; <a href="../../categories/image.html">Image Tools</a> &rsaquo; Color Picker</div>
    <h1>Color Picker</h1>
    <p>Pick a color or paste a HEX value — instantly convert between HEX, RGB, and HSL. Every value is one-click copyable.</p>
  </div>

  <div class="card">
    <div class="swatch" id="swatch"></div>
    <div class="row" style="margin-top:10px;">
      <input type="color" id="color" value="#2563eb" />
    </div>
    <div class="hex-row" style="margin-top:10px;">
      <input type="text" id="hexIn" value="#2563EB" />
      <button class="btn" data-copy="hex" style="white-space:nowrap;">Copy</button>
    </div>
    <div style="margin-top:14px;">
      <div class="fmt-row"><span class="fmt-label">HEX</span><span class="fmt-value" id="vHex">#2563EB</span><button class="btn btn--sm btn--ghost" data-copy="hex">Copy</button></div>
      <div class="fmt-row"><span class="fmt-label">RGB</span><span class="fmt-value" id="vRgb">rgb(37, 99, 235)</span><button class="btn btn--sm btn--ghost" data-copy="rgb">Copy</button></div>
      <div class="fmt-row"><span class="fmt-label">RGBA</span><span class="fmt-value" id="vRgba">rgba(37, 99, 235, 1)</span><button class="btn btn--sm btn--ghost" data-copy="rgba">Copy</button></div>
      <div class="fmt-row"><span class="fmt-label">HSL</span><span class="fmt-value" id="vHsl">hsl(221, 83%, 53%)</span><button class="btn btn--sm btn--ghost" data-copy="hsl">Copy</button></div>
      <div class="fmt-row"><span class="fmt-label">HSLA</span><span class="fmt-value" id="vHsla">hsla(221, 83%, 53%, 1)</span><button class="btn btn--sm btn--ghost" data-copy="hsla">Copy</button></div>
    </div>
  </div>

  <div class="section">
    <h2>How it works</h2>
    <ol class="steps">
      <li>Click the color picker above or type a HEX value into the input.</li>
      <li>All conversions (RGB, RGBA, HSL, HSLA) update automatically.</li>
      <li>Click "Copy" next to any format to copy to clipboard.</li>
    </ol>
  </div>

  <div class="section">
    <h2>Related tools</h2>
    <div class="related-grid">
      <a href="color-converter.html">Color Converter</a>
      <a href="image-compressor.html">Image Compressor</a>
      <a href="image-resizer.html">Image Resizer</a>
      <a href="background-remover.html">Background Remover</a>
    </div>
  </div>

  <footer class="footer">
    <div class="footer-links">
      <a href="color-converter.html">Color Converter</a>
      <a href="image-compressor.html">Image Compressor</a>
      <span style="color:var(--border);margin:0 6px;">|</span>
      <a href="../../about.html">About</a>
      <a href="../../privacy.html">Privacy</a>
      <a href="../../disclaimer.html">Disclaimer</a>
    </div>
    <p class="footer-copy">&copy; 2026 My Tool Lab. All rights reserved.</p>
  </footer>
</div>

<script>
(function(){
  var color=document.getElementById('color');
  var hexIn=document.getElementById('hexIn');
  var swatch=document.getElementById('swatch');
  var vHex=document.getElementById('vHex');
  var vRgb=document.getElementById('vRgb');
  var vRgba=document.getElementById('vRgba');
  var vHsl=document.getElementById('vHsl');
  var vHsla=document.getElementById('vHsla');
  function hexToRgb(hex){hex=hex.replace('#','').trim();if(hex.length===3)hex=hex.split('').map(function(c){return c+c;}).join('');if(!/^[0-9a-fA-F]{6}$/.test(hex))return null;return{r:parseInt(hex.substring(0,2),16),g:parseInt(hex.substring(2,4),16),b:parseInt(hex.substring(4,6),16)};}
  function rgbToHsl(r,g,b){r/=255;g/=255;b/=255;var max=Math.max(r,g,b),min=Math.min(r,g,b);var h,s,l=(max+min)/2;if(max===min){h=s=0;}else{var d=max-min;s=l>0.5?d/(2-max-min):d/(max+min);switch(max){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;case b:h=(r-g)/d+4;break;}h/=6;}return{h:Math.round(h*360),s:Math.round(s*100),l:Math.round(l*100)};}
  function update(hex){hex=hex.toUpperCase().replace(/[^0-9A-F#]/g,'');if(hex.charAt(0)!=='#')hex='#'+hex;if(hex.length>7)hex=hex.substring(0,7);var rgb=hexToRgb(hex);if(!rgb)return;var hsl=rgbToHsl(rgb.r,rgb.g,rgb.b);swatch.style.background='rgb('+rgb.r+', '+rgb.g+', '+rgb.b+')';color.value=hex;hexIn.value=hex;vHex.textContent=hex;vRgb.textContent='rgb('+rgb.r+', '+rgb.g+', '+rgb.b+')';vRgba.textContent='rgba('+rgb.r+', '+rgb.g+', '+rgb.b+', 1)';vHsl.textContent='hsl('+hsl.h+', '+hsl.s+'%, '+hsl.l+'%)';vHsla.textContent='hsla('+hsl.h+', '+hsl.s+'%, '+hsl.l+'%, 1)';}
  color.addEventListener('input',function(){update(color.value);});
  hexIn.addEventListener('input',function(){if(hexToRgb(hexIn.value))update(hexIn.value);});
  hexIn.addEventListener('blur',function(){if(!hexToRgb(hexIn.value))hexIn.value=color.value;});
  function getVal(key){if(key==='hex')return vHex.textContent;if(key==='rgb')return vRgb.textContent;if(key==='rgba')return vRgba.textContent;if(key==='hsl')return vHsl.textContent;if(key==='hsla')return vHsla.textContent;return'';}
  document.querySelectorAll('[data-copy]').forEach(function(btn){btn.addEventListener('click',function(){var k=btn.getAttribute('data-copy');var t=getVal(k);var done=function(){var old=btn.textContent;btn.textContent='Copied!';btn.classList.add('copied');setTimeout(function(){btn.textContent=old;btn.classList.remove('copied');},1000);};if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(t).then(done).catch(done);}else{var ta=document.createElement('textarea');ta.value=t;document.body.appendChild(ta);ta.select();try{document.execCommand('copy');}catch(e){}document.body.removeChild(ta);done();}});});
})();
</script>
</body>
</html>
